# =============================================================================
# Codra — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local for local development.
# All variables are required for full operation unless marked [optional].
# For Netlify deployments, set these in the Netlify Dashboard → Site Settings
# → Environment Variables (NOT in netlify.toml, which is version-controlled).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Database & Auth
# Get these from: https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side Supabase (Netlify Functions only — never expose to client)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Stripe — Billing
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development, live keys for production.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# AI Providers — Platform Keys (server-side only)
# Codra uses a shared platform-key model: all users share these keys,
# and usage is tracked per-user for billing. Never expose these client-side.
# -----------------------------------------------------------------------------
# AIMLAPI — https://aimlapi.com/app/keys
AIMLAPI_API_KEY=your_aimlapi_key

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=...

# Cohere — https://dashboard.cohere.com/api-keys
COHERE_API_KEY_PROD=...

# HuggingFace — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# DeepAI — https://deepai.org/dashboard
DEEPAI_API_KEY=...

# -----------------------------------------------------------------------------
# Search / Retrieval Providers
# -----------------------------------------------------------------------------
# Brave Search API — https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=BSA...

# Tavily — https://app.tavily.com
TAVILY_API_KEY=tvly-...

# -----------------------------------------------------------------------------
# GitHub OAuth — for GitHub integration features
# Create an OAuth App at: https://github.com/settings/developers
# Callback URL: https://your-netlify-site.netlify.app/.netlify/functions/github-oauth-callback
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=Iv1....
GITHUB_CLIENT_SECRET=...

# -----------------------------------------------------------------------------
# Application Secrets — for session signing and encryption
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
CODRA_APP_SECRET=replace_with_32_byte_random_string
ENCRYPTION_APP_SECRET=replace_with_32_byte_random_string

# -----------------------------------------------------------------------------
# Cloudinary — Asset Storage & Transformation
# Get these from: https://cloudinary.com/console/settings/api-keys
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -----------------------------------------------------------------------------
# CORS & Network
# URL is set automatically by Netlify in deployed environments.
# For local dev with Netlify Dev, set to http://localhost:8881
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://your-netlify-site.netlify.app
# URL=https://your-netlify-site.netlify.app  # set automatically by Netlify

# Admin access (comma-separated email list)
ADMIN_EMAILS=admin@example.com

# -----------------------------------------------------------------------------
# Analytics — PostHog
# Get these from: https://app.posthog.com/settings/project
# [optional] — analytics are disabled if these are unset
# -----------------------------------------------------------------------------
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_ANALYTICS_DEBUG=false
