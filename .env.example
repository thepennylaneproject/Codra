# CODRA ANALYTICS CONFIGURATION
# -----------------------------------------------------------------------------
# Get your keys from https://app.posthog.com

# PostHog Project API Key
VITE_POSTHOG_KEY=phc_your_key_here

# PostHog Instance URL (defaults to https://app.posthog.com)
VITE_POSTHOG_HOST=https://app.posthog.com

# Analytics Debug Mode (logs events to console if set to 'true')
VITE_ANALYTICS_DEBUG=true
