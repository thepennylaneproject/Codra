
import { useOnboardingStore } from '../store';
import { Button } from '@/components/ui/Button';

const DESKS = [
    { id: 'copy', label: 'Copy Desk', description: 'Automated grammar, style guides, and voice consistency checks.' },
    { id: 'art', label: 'Art Department', description: 'AI image generation, layout assistance, and media management.' },
    { id: 'fact', label: 'Research & Fact Checking', description: 'Verification of claims against trusted sources.' },
    { id: 'seo', label: 'Distribution & SEO', description: 'Metadata optimization and search readiness.' },
    { id: 'legal', label: 'Legal & Compliance', description: 'Rights management and policy adherence reviews.' },
];

export const DesksStep = () => {
    const { data, updateData, setStep } = useOnboardingStore();

    const toggleDesk = (deskId: string) => {
        const current = data.selectedDesks || [];
        if (current.includes(deskId)) {
            updateData({ selectedDesks: current.filter(d => d !== deskId) });
        } else {
            updateData({ selectedDesks: [...current, deskId] });
        }
    };

    return (
        <div className="space-y-12 animate-in fade-in slide-in-from-bottom-4 duration-700 ease-out">
            <header className="space-y-4">
                <h1 className="text-xl md:text-xl font-normal tracking-tight text-zinc-900 dark:text-zinc-50">
                    Staffing & Desks
                </h1>
                <p className="text-xl text-zinc-500 font-normal max-w-lg">
                    Which specialized departments does this project require?
                </p>
            </header>

            <div className="space-y-6">
                <div className="grid grid-cols-1 gap-4">
                    {DESKS.map(desk => {
                        const isSelected = data.selectedDesks?.includes(desk.id);
                        return (
                            <Button
                                key={desk.id}
                                onClick={() => toggleDesk(desk.id)}
                                className={`group relative p-6 text-left border transition-all duration-300 ${isSelected
                                    ? 'border-zinc-900 bg-zinc-50 dark:border-zinc-100 dark:bg-zinc-900/50'
                                    : 'border-zinc-200 hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600'
                                    }`}
                            >
                                <div className="flex items-start justify-between">
                                    <div>
                                        <h3 className={`text-base font-medium transition-colors ${isSelected ? 'text-zinc-900 dark:text-zinc-100' : 'text-zinc-500 group-hover:text-zinc-900 dark:text-zinc-500 dark:group-hover:text-zinc-300'
                                            }`}>
                                            {desk.label}
                                        </h3>
                                        <p className="mt-1 text-sm text-zinc-400 max-w-md">
                                            {desk.description}
                                        </p>
                                    </div>
                                    <div className={`w-5 h-5 border flex items-center justify-center transition-colors ${isSelected ? 'bg-zinc-900 border-zinc-900 dark:bg-zinc-100 dark:border-zinc-100' : 'border-zinc-300 dark:border-zinc-700'
                                        }`}>
                                        {isSelected && (
                                            <svg className="w-3 h-3 text-white dark:text-zinc-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M5 13l4 4L19 7" />
                                            </svg>
                                        )}
                                    </div>
                                </div>
                            </Button>
                        );
                    })}
                </div>

                <div className="flex justify-between pt-8 border-t border-zinc-100 dark:border-zinc-900">
                    <Button
                        onClick={() => setStep('read')}
                        className="text-sm font-medium text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
                    >
                        &larr; Back
                    </Button>
                    <Button
                        onClick={() => setStep('budget')}
                        className="group flex items-center gap-2 text-base font-medium text-zinc-900 dark:text-zinc-100 hover:text-amber-600 dark:hover:text-amber-400 transition-colors"
                    >
                        Budget & Policy
                        <span className="block w-6 h-[1px] bg-current group-hover:w-10 transition-all" />
                    </Button>
                </div>
            </div>
        </div>
    );
};
