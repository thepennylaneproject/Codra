{
  "name": "codra",
  "version": "0.2.0",
  "type": "module",
  "description": "AI workflow tool with multi-provider integration",
  "scripts": {
    "predev": "npm run tokens:generate",
    "dev": "vite",
    "prebuild": "tsx scripts/generate-css-tokens.ts && tsx scripts/generate-tailwind-config.ts",
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192\" tsc && NODE_OPTIONS=\"--max-old-space-size=8192\" vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint src",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:design": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:design",
    "test": "vitest",
    "test:auth": "vitest run --grep auth",
    "audit:decisions": "tsx scripts/audit-decisions.ts",
    "audit:accent": "tsx scripts/review-accent-audit.ts",
    "audit:accent:ci": "tsx scripts/review-accent-audit.ts --ci",
    "audit:bundle": "npm run build && tsx scripts/analyze-bundle.ts",
    "audit:all": "npm run audit:decisions && npm run audit:accent",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "tokens:generate": "tsx scripts/generate-css-tokens.ts && tsx scripts/generate-tailwind-config.ts",
    "tokens:check": "npm run tokens:generate && git diff --exit-code src/styles/generated-tokens.css tailwind.config.generated.js",
    "pipeline:setup": "tsx scripts/pipeline/setup-cloudinary.ts",
    "pipeline:enrich": "tsx scripts/pipeline/enrich-assets.ts",
    "pipeline:index": "tsx scripts/pipeline/generate-index.ts --materialize-slots",
    "pipeline:validate": "tsx scripts/pipeline/validate-assets.ts --report",
    "pipeline:all": "npm run pipeline:enrich && npm run pipeline:validate && npm run pipeline:index"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@netlify/functions": "^2.8.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.86.2",
    "@tanstack/react-query": "^5.90.12",
    "@types/canvas-confetti": "^1.9.0",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@xyflow/react": "^12.10.0",
    "autoprefixer": "^10.4.20",
    "canvas-confetti": "^1.9.4",
    "cloudinary": "^2.8.0",
    "clsx": "^2.1.1",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "html2canvas": "^1.4.1",
    "immer": "^11.0.1",
    "jsonpath-plus": "^10.3.0",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.556.0",
    "monaco-editor": "^0.55.1",
    "octokit": "^5.0.5",
    "p-limit": "^7.2.0",
    "postcss": "^8.4.41",
    "postcss-import": "^16.1.1",
    "posthog-js": "^1.309.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.2",
    "react-speech-recognition": "^4.0.1",
    "recharts": "^3.5.1",
    "sharp": "^0.34.5",
    "shepherd.js": "^14.5.1",
    "stripe": "^20.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.10",
    "ts-jobspy": "^2.0.3",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vite": "^5.4.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.19.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-speech-recognition": "^3.9.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^8.57.0",
    "eslint-plugin-codra": "file:eslint-plugin-codra",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-storybook": "^10.1.11",
    "glob": "^11.0.0",
    "playwright": "^1.57.0",
    "storybook": "^10.1.11",
    "stylelint": "^16.7.0",
    "stylelint-config-standard": "^36.0.0",
    "tsx": "^4.19.2",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
